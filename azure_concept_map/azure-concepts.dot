digraph AzureConcepts {
  rankdir=LR;
  graph [pad=0.2, nodesep=0.5, ranksep=0.8];
  node [shape=box, style=rounded, fontname=Helvetica, fontsize=11, margin=0.18];
  edge [fontname=Helvetica, fontsize=10];
  "tenant" [label="Tenant", URL="html/tenant.html", target="_top", tooltip="Tenant"];
  "management-group" [label="Management Group", URL="html/management-group.html", target="_top", tooltip="Management Group"];
  "subscription" [label="Subscription", URL="html/subscription.html", target="_top", tooltip="Subscription"];
  "resource-group" [label="Resource Group", URL="html/resource-group.html", target="_top", tooltip="Resource Group"];
  "entra-id" [label="Microsoft Entra ID", URL="html/entra-id.html", target="_top", tooltip="Microsoft Entra ID"];
  "rbac" [label="Azure RBAC", URL="html/rbac.html", target="_top", tooltip="Azure RBAC"];
  "policy" [label="Azure Policy", URL="html/policy.html", target="_top", tooltip="Azure Policy"];
  "vnet" [label="Virtual Network (VNet)", URL="html/vnet.html", target="_top", tooltip="Virtual Network (VNet)"];
  "vpn-gateway" [label="VPN Gateway", URL="html/vpn-gateway.html", target="_top", tooltip="VPN Gateway"];
  "expressroute" [label="ExpressRoute", URL="html/expressroute.html", target="_top", tooltip="ExpressRoute"];
  "key-vault" [label="Key Vault", URL="html/key-vault.html", target="_top", tooltip="Key Vault"];
  "monitor" [label="Azure Monitor", URL="html/monitor.html", target="_top", tooltip="Azure Monitor"];
  "defender" [label="Defender for Cloud", URL="html/defender.html", target="_top", tooltip="Defender for Cloud"];
  "arc" [label="Azure Arc", URL="html/arc.html", target="_top", tooltip="Azure Arc"];
  "on-prem" [label="On-premises Environment", URL="html/on-prem.html", target="_top", tooltip="On-premises Environment"];
  "tenant" -> "management-group" [label="identity context"];
  "management-group" -> "subscription" [label="contains"];
  "subscription" -> "resource-group" [label="contains"];
  "entra-id" -> "rbac" [label="authenticates"];
  "rbac" -> "management-group" [label="authorizes at scope"];
  "rbac" -> "subscription" [label="authorizes at scope"];
  "rbac" -> "resource-group" [label="authorizes at scope"];
  "policy" -> "management-group" [label="governs"];
  "policy" -> "subscription" [label="governs"];
  "resource-group" -> "vnet" [label="contains"];
  "resource-group" -> "key-vault" [label="contains"];
  "vnet" -> "vpn-gateway" [label="connects via"];
  "vnet" -> "expressroute" [label="connects via"];
  "on-prem" -> "vpn-gateway" [label="connects to"];
  "on-prem" -> "expressroute" [label="connects to"];
  "monitor" -> "resource-group" [label="observes"];
  "monitor" -> "on-prem" [label="observes"];
  "defender" -> "subscription" [label="assesses"];
  "defender" -> "on-prem" [label="protects"];
  "arc" -> "on-prem" [label="extends governance to"];
  "arc" -> "monitor" [label="integrates with"];
  "arc" -> "defender" [label="integrates with"];
}
